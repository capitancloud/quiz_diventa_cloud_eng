# MailerLite — API key (da Integrations → API su mailerlite.com)
VITE_MAILERLITE_API_KEY=

# MailerLite — ID del gruppo/segmento dove aggiungere i lead (opzionale)
VITE_MAILERLITE_GROUP_ID=

# Webhook generico (Zapier, Make, ActiveCampaign…) — opzionale
VITE_LEAD_WEBHOOK_URL=

# URL della pagina a cui rimanda il bottone CTA nella pagina risultato
VITE_CTA_URL=https://capitancloud.it
